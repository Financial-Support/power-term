
.animate-fast
  animation-duration .2s
.sidebar-panel
  position absolute
  left 0
  top 0
  bottom 0
  z-index 200
  width 0
  overflow-y scroll
  background var(--main)
  .item-list-unit:hover
    .list-item-remove
      display none !important

.sidebar
  position absolute
  left 0
  top 0
  /* Use CSS variable for sidebar width (falls back to 180px if not set) */
  width var(--sidebar-width, 180px)
  z-index 100
  bottom 0
  background var(--main-dark)

  .item-list
    padding-right 0
.sidebar-pin-top
  position absolute
  left 0
  right 0
  top 0
  height 112px
.sidebar-panel-bookmarks
.sidebar-panel-history
  position absolute
  left 0
  right 0
  top 112px
  bottom 0
  overflow-y scroll
  .item-list-wrap
    overflow-y hidden
.not-system-ui.is-mac
  .sidebar-bar
    margin-top 30px
    display flex
    flex-direction column
    padding 0 10px
.type-bookmarks
  .bookmarks-panel
    width 100%
.type-history
  .history-panel
    width 100%
.control-icon-text
  color var(--text)
  margin-left 12px
  font-size 13px
  line-height 1
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  vertical-align: middle
  opacity: .95
  &:hover
    color var(--success)
.control-icon-wrap
  display: flex
  align-items: center
  row-gap 12px
  /* padding left/right to create breathable space */
  padding 8px 10px
  /* add vertical separation between items */
  margin 4px 0
  position: relative
  cursor: pointer
  width: 100%
  box-sizing: border-box
  border-radius var(--sidebar-radius, 6px)
  /* Only transition background-color for smooth hover/active */
  transition: background-color .2s ease-out, color .2s ease-out
  /* Hover: use provided background color (no border) */
  &:hover
    background var(--sidebar-hover-bg, #706f6f)
    .control-icon
      color var(--text-light)
  &.active
    /* active uses the same requested color (or variant) */
    background var(--sidebar-active-bg, #706f6f)
    color var(--text-light)
    .control-icon
      color var(--text-light)
  .control-icon
    color var(--text-dark)
    cursor pointer
    pointer-events: auto
    &:hover
      color var(--text-light)
.sidebar-list
  position absolute
  /* place sidebar-list to the right of the expanded sidebar using CSS variable */
  left var(--sidebar-width, 180px)
  top 0
  bottom 0
  z-index 200
  width 0

.pinned
  .sidebar-list
    top 0
    .sidebar-panel
      top 0
      padding-top 36px
  .drag-handle
    display block
  .sidebar-panel
    .pinned
      color var(--success)
//btns
.btns
  background var(--main-dark)
  border-color var(--primary)
  .open-about-icon
    color var(--text-dark)
    &:hover
      color var(--text-light)

.btns .upgrade-icon
  color var(--success)
.close-info-modal
  cursor pointer
  &:hover
    color var(--text-light)
.logo-filter
  filter invert(80%)
.sidebar-inner
  padding-right 8px
